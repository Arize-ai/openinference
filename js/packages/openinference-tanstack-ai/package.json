{
  "name": "@arizeai/openinference-tanstack-ai",
  "version": "0.0.0",
  "private": false,
  "description": "OpenInference middleware for TanStack AI",
  "keywords": [
    "ai",
    "openinference",
    "opentelemetry",
    "tanstack"
  ],
  "license": "Apache-2.0",
  "author": "oss-devs@arize.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Arize-ai/openinference.git"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js"
    }
  },
  "scripts": {
    "prebuild": "rimraf dist && pnpm run version:update",
    "build": "tsc --build tsconfig.esm.json && tsc-alias -p tsconfig.esm.json",
    "postbuild": "echo '{\"type\": \"module\"}' > ./dist/esm/package.json",
    "version:update": "../../scripts/version-update.js",
    "type:check": "tsc --noEmit",
    "test": "vitest run --typecheck"
  },
  "dependencies": {
    "@arizeai/openinference-core": "workspace:*",
    "@arizeai/openinference-semantic-conventions": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/core": "^1.30.1"
  },
  "devDependencies": {
    "@opentelemetry/exporter-trace-otlp-proto": "^0.50.0",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "@opentelemetry/sdk-trace-node": "^1.30.1",
    "@tanstack/ai": "^0.10.0",
    "@tanstack/ai-anthropic": "^0.7.2",
    "@tanstack/ai-openai": "^0.7.3",
    "@types/node": "^20.14.11",
    "typescript": "^5.8.3",
    "vitest": "^4.0.3",
    "zod": "^4.2.0"
  },
  "peerDependencies": {
    "@tanstack/ai": ">=0.10.0"
  }
}
