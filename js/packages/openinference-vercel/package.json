{
  "name": "@arizeai/openinference-vercel",
  "version": "3.1.0",
  "private": false,
  "description": "OpenInference utilities for ingesting Vercel AI SDK spans",
  "keywords": [
    "llm",
    "nextjs",
    "openinference",
    "opentelemetry",
    "vercel"
  ],
  "homepage": "https://github.com/arize-ai/openinference/tree/main/js/packages/openinference-vercel",
  "bugs": {
    "url": "https://github.com/Arize-ai/openinference/issues"
  },
  "license": "Apache-2.0",
  "author": "oss-devs@arize.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arize-ai/openinference.git"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js"
    },
    "./utils": {
      "types": "./dist/esm/utils.d.ts",
      "import": "./dist/esm/utils.js"
    },
    "./types": {
      "types": "./dist/esm/types.d.ts",
      "import": "./dist/esm/types.js"
    }
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc --build tsconfig.esm.json && tsc-alias -p tsconfig.esm.json",
    "postbuild": "echo '{\"type\": \"module\"}' > ./dist/esm/package.json",
    "type:check": "tsc --noEmit && tsc -p tsconfig.examples.json",
    "test": "vitest run --typecheck"
  },
  "dependencies": {
    "@arizeai/openinference-core": "workspace:*",
    "@arizeai/openinference-genai": "workspace:*",
    "@arizeai/openinference-semantic-conventions": "workspace:*",
    "@opentelemetry/core": "^1.30.1",
    "@opentelemetry/semantic-conventions": ">=1.41.1 <2.0.0"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^4.0.0",
    "@ai-sdk/otel": "^1.0.0",
    "@opentelemetry/api": ">=1.7.0 <2.0.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.57.2",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-trace-base": ">=1.19.0 <2.0.0",
    "@opentelemetry/sdk-trace-node": "^1.30.1",
    "@types/node": "^22.19.3",
    "ai": "^7.0.0",
    "typescript": "^7.0.2",
    "vitest": "^4.0.3",
    "zod": "^3.24.3"
  },
  "peerDependencies": {
    "@ai-sdk/otel": "^1.0.0",
    "@opentelemetry/api": ">=1.7.0 <2.0.0",
    "@opentelemetry/semantic-conventions": ">=1.41.1 <2.0.0",
    "ai": "^7.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
