go 1.25.0

// In-repo workspace: lets `go build` / `go test` in any submodule
// resolve cross-package deps from the working tree without requiring
// the dependency to be tagged. Customers consuming the modules via
// `go get` ignore this file entirely — the published modules' go.mod
// require lines resolve via the Go module proxy.
use (
	./openinference-semantic-conventions
	./openinference-instrumentation
	./openinference-instrumentation-anthropic-sdk-go
	./openinference-instrumentation-anthropic-sdk-go/examples/auto-instrumentation
	./openinference-instrumentation-anthropic-sdk-go/examples/manual-instrumentation
	./openinference-instrumentation-openai-go
	./openinference-instrumentation-openai-go/examples/auto-instrumentation
	./openinference-instrumentation-openai-go/examples/manual-instrumentation
)
